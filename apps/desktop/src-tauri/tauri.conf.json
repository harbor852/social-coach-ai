{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpeakUp AI",
  "version": "0.3.0",
  "identifier": "com.speakup.app",
  "build": {
    "beforeDevCommand": "cd ../../web && node ../../web/node_modules/next/dist/bin/next dev --port 3000",
    "beforeBuildCommand": "cd ../../web && node ../../web/node_modules/next/dist/bin/next build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SpeakUp AI - 社交成长教练",
        "width": 430,
        "height": 932,
        "minWidth": 375,
        "minHeight": 667,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
