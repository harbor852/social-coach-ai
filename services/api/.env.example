# LLM Provider: mock | kimi | deepseek | openai | anthropic
LLM_PROVIDER=mock

# Kimi (Moonshot)
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI (also works for any OpenAI-compatible endpoint)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Database
DATABASE_URL=sqlite:///./social_coach.db

# TTS (Text-to-Speech) Provider
# Options: mock | alibaba | openai
TTS_PROVIDER=mock
TTS_API_KEY=
TTS_MODEL=cosyvoice-v1
TTS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TTS_VOICE=longxiaochun

# Voice features
SAVE_AUDIO=false

# App
DEBUG=true
CORS_ORIGINS=http://localhost:3000
